# LLM (OpenAI or Anthropic — set one)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o-mini

# ZoomInfo GTM API (OAuth)
ZOOMINFO_CLIENT_ID=
ZOOMINFO_CLIENT_SECRET=
ZOOMINFO_USERNAME=
ZOOMINFO_PASSWORD=

# Gmail OAuth (path to client secrets JSON from Google Cloud)
GMAIL_CREDENTIALS_PATH=credentials/gmail_client_secret.json
GMAIL_TOKEN_PATH=credentials/gmail_token.json

# Outreach identity
SENDER_NAME=Your Name
SENDER_FIRM=Your Firm
SENDER_EMAIL=
MAILING_ADDRESS=Your physical mailing address
OUTREACH_PITCH=Brief description of what you offer to GCC institutional investors

# Daily caps
EMAIL_DAILY_CAP=70
WHATSAPP_DAILY_CAP=30

# Pipeline defaults
DRY_RUN=true
COMPANY_CONFIDENCE_THRESHOLD=0.55
CONTACT_CONFIDENCE_THRESHOLD=0.6

# Optional GCC phone validation
KHALEEJI_API_KEY=

# Database
DATABASE_URL=sqlite:///./data/outreach.db
